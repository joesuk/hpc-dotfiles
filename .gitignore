# Ignore everything by default
/*

# Re-include the dotfiles you actually track
!/.bashrc
!/.bash_profile
!/.zshenv

# For directories: re-include the dir, ignore its contents, then re-include specifics
!/.config/
/.config/*
!/.config/nvim/
!/.config/zsh/
!/.config/shell/
!/.config/tmux/

!/.local/
/.local/*
!/.local/bin/
